{
  "name": "@eulerstream/nats-cloudflare",
  "version": "0.1.0",
  "description": "NATS transport for Cloudflare Workers using TCP sockets",
  "type": "module",
  "main": "lib/mod.js",
  "types": "lib/mod.d.ts",
  "exports": {
    ".": {
      "types": "./lib/mod.d.ts",
      "import": "./lib/mod.js"
    },
    "./internal": {
      "types": "./lib/cloudflare_transport.d.ts",
      "import": "./lib/cloudflare_transport.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "nats",
    "cloudflare",
    "workers",
    "transport"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EulerStream/nats-cloudflare-transport.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@nats-io/nats-core": "^3.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260422.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
